       'dew_point_2m ', 'pressure_msl ']].copy()




import hdbscan

# Initialize HDBSCAN model
# min_cluster_size: The minimum size of clusters that HDBSCAN should find.
# min_samples: The number of samples in a neighborhood for a point to be considered as a core point.
#              This includes the point itself.
# metric: The metric to use when calculating distance between points.

hdbscan_clustering = hdbscan.HDBSCAN(min_cluster_size=5, min_samples=5, metric='euclidean')

# Fit the model and predict clusters
# HDBSCAN returns -1 for noise points
clusters_hdbscan = hdbscan_clustering.fit_predict(df5)

# Add the cluster labels to df5
df5['cluster_labels_hdbscan'] = clusters_hdbscan

print("HDBSCAN Clustering applied. First 5 rows of df5 with new cluster labels:")
print(df5.head())

print("\nValue counts of the generated HDBSCAN clusters (cluster -1 indicates noise):")
print(df5['cluster_labels_hdbscan'].value_counts())

